<Window x:Class="WPF_LocalChatSqlite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_LocalChatSqlite"
        mc:Ignorable="d"
        Title="Local Chat"
        Height="500"
        Width="850"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#2D2D30"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,0,15">

            <TextBlock Text="💭 Czat"
               Foreground="White"
               FontSize="26"
               FontWeight="Bold"/>
        </Border>

        <Border Grid.Row="1"
                Background="#252526"
                CornerRadius="10"
                Padding="10">

            <ListBox x:Name="MessagesList"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="White"
                     FontSize="15">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,5"/>
                    </Style>
                </ListBox.ItemContainerStyle>

            </ListBox>

        </Border>

        <Border Grid.Row="2"
                Background="#2D2D30"
                CornerRadius="10"
                Padding="10"
                Margin="0,15,0,0">

            <DockPanel LastChildFill="False">

                <TextBox x:Name="MessageBox"
                         KeyDown="MessageBox_KeyDown"
                         Height="40"
                         FontSize="16"
                         Foreground="White"
                         Background="#3C3C3C"
                         BorderThickness="0"
                         Padding="10"
                         Margin="0,0,10,0"
                         VerticalContentAlignment="Center"
                         MinWidth="600"
                         DockPanel.Dock="Left"/>

                <Button Content="Wyślij"
                        Width="120"
                        Height="40"
                        FontSize="15"
                        FontWeight="Bold"
                        Background="#007ACC"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Send_Click">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#007ACC"
                                        CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>

                </Button>

            </DockPanel>

        </Border>

    </Grid>
</Window>
