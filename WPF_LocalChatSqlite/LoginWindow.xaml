<Window x:Class="WPF_LocalChatSqlite.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login" Height="220" Width="400" WindowStartupLocation="CenterScreen" Background="#1E1E1E">
    <Grid Margin="15">
        <Border Background="#2D2D30" CornerRadius="10" Padding="15">
            <StackPanel>
                <TextBlock Text="Wprowadź nickname" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBox x:Name="NicknameBox" Height="36" FontSize="14" Padding="8" Background="#3C3C3C" Foreground="White" BorderThickness="0"/>
                <TextBlock x:Name="ErrorText" Foreground="#FF6B6B" FontSize="12" Visibility="Collapsed" Margin="0,6,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="Zaloguj" Width="100" Height="36" Click="Login_Click" Background="#007ACC" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
